[alias]
    prenv = "!f() { git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo 'Not inside a git repository'; exit 1; }; git commit -m 'prenv' --allow-empty || exit $?; upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); [ -z \"$upstream\" ] && { echo 'Commit created. No upstream configured, so skipping push.'; exit 0; }; ahead=$(git rev-list --count \"$upstream..HEAD\" 2>/dev/null); if [ \"$ahead\" -eq 1 ]; then git push; else echo \"Commit created. Skipping push because branch is $ahead commits ahead of $upstream.\"; fi; }; f"
